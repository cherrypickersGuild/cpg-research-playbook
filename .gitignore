# Tarballs — release artifacts, not source. Individual files are committed instead.
*.tar.gz

# macOS / editor noise
.DS_Store
*.swp
*~

# Python bytecode caches (regenerated when scripts/tests run)
__pycache__/
*.pyc

# Transient per-run artifacts — regenerated every run; the persistent truth
# lives in state/ax_case_db.json, state/entity_registry.json, state/category_registry.json.
state/*.err
state/news_hits.json
state/news_case_db_*.json
state/news_entity_batch.json
state/harvest_*
state/logs/
state/backups/
# deterministic GitHub metadata cache — regenerated/refreshed per run, never committed
state/github_meta_cache.json
# ax_case_harvest transient scratch files — listed explicitly (not a wildcard)
# so state/ax_case_harvest_registry.json (the persistent output) is never
# accidentally matched.
state/ax_case_harvest_hits.json
state/ax_case_harvest_batch.json
state/ax_case_harvest_attempted.json
state/ax_case_harvest.err
state/ax_case_harvest_raw_candidates.json
state/ax_case_harvest_raw_extract.json
schedule/logs/
